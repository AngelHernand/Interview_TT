# ── Variables de entorno para Docker Compose ─────────
# Copiar este archivo como .env y ajustar los valores

# Password de SQL Server (mínimo 8 chars, mayúsculas, minúsculas, números y especiales)
SA_PASSWORD=DockerPass123!

# Clave secreta para JWT (mínimo 32 caracteres)
JWT_SECRET=Docker_Clave_Secreta_MuySegura_32chars!!
